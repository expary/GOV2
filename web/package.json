    "lint": "eslint src --ext .js,.vue"
  },
  "dependencies": {
    "@lucide/vue": "^1.17.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.35",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^9.28.0",
    "eslint-plugin-vue": "^9.33.0",
    "vite": "^8.0.16"
  }
}
