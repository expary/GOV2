{
  "name": "gov2-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "api:generate": "node ../scripts/generate-web-api-contract.mjs",
    "api:check": "node ../scripts/generate-web-api-contract.mjs --check && node ../scripts/check-web-api-usage.mjs",
    "test": "node --test tests/*.test.mjs",
    "dev": "vite --host 0.0.0.0",
